import openai
import os
from dotenv import load_dotenv

load_dotenv()
client = openai.OpenAI(api_key=os.getenv("OPENAI_API_KEY"))

def generate_social_bundle(business_name, industry, tone, goal):
    """Génère un pack complet de contenu via GPT-4o"""
    
    prompt = f"""
    Tu es un expert en marketing viral pour {industry}.
    Nom du business: {business_name}
    Objectif: {goal}
    Ton de marque: {tone}
    
    Génère un JSON contenant :
    1. 3 Posts Instagram (Caption + Hook)
    2. 2 Scripts TikTok/Reels (Scène par scène)
    3. Un calendrier éditorial de 7 jours
    4. 10 Hashtags performants
    5. Un CTA (Call to action) irrésistible.
    """
    
    response = client.chat.completions.create(
        model="gpt-4-turbo-preview",
        messages=[{"role": "system", "content": "Tu es un Copywriter Senior."},
                  {"role": "user", "content": prompt}],
        response_format={ "type": "json_object" }
    )
    return response.choices[0].message.content
